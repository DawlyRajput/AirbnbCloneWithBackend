<%- include('../partials/head') %>
</head>
<body>
    <%- include('../partials/nav') %>
    <main class="home-details">
        <h2>
            Details of <%= home.housename %>
        </h2>
        
        <div class="content-grid">
            <div class="image-container">
                <img src="<%= home.photoUrl %>" alt="<%= home.name %>">
            </div>
            
            <div class="info-section">
                <div class="info-block">
                    <h3>Description</h3>
                    <p><%= home.description %></p>
                </div>

                <div class="info-block">
                    <h3>Location</h3>
                    <p><%= home.location %></p>
                </div>
                
                <div class="info-block">
                    <h3>Price</h3>
                    <p class="price">$<%= home.price %> / night</p>
                </div>
                
                <div class="info-block">
                    <h3>Rating</h3>
                    <div class="rating">
                        <span class="star">★</span>
                        <span><%= home.rating %> / 5</span>
                    </div>
                </div>
                <div >
                     <%- include('../partials/favourite') %>
                </div>
            </div>

        </div>
    </main>
</body>
</html>